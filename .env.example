# TheGradual Frontend Environment Variables
# Copy this to .env.local for local development

# AWS Region
VITE_AWS_REGION=us-east-2

# Cognito User Pool
VITE_COGNITO_USER_POOL_ID=us-east-2_84owr0tPc
VITE_COGNITO_CLIENT_ID=354hrppeaog6o66u2fbdtdeqc1  # Server client ID (used by both frontend and BFF)

# Cognito Identity Pool (for anonymous + authenticated access)
VITE_COGNITO_IDENTITY_POOL_ID=us-east-2:2cb60670-38b7-4876-858c-e9102a34693d

# Cognito Hosted UI Domain
VITE_COGNITO_DOMAIN=thegradual-auth.auth.us-east-2.amazoncognito.com

# BFF Lambda Endpoint
VITE_BFF_ENDPOINT=https://cwxiir473hvnurcous3ogcz3xa0anqfc.lambda-url.us-east-2.on.aws

# App URLs (for OAuth redirects)
VITE_APP_URL_PROD=https://thegradual.com
VITE_APP_URL_DEV=http://localhost:5555
